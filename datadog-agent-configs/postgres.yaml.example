# Copy this to /opt/datadog-agent/etc/conf.d/postgres.d/conf.yaml
# (macOS) or /etc/datadog-agent/conf.d/postgres.d/conf.yaml (Linux)
#
# Prerequisites:
#   1. Create a 'datadog' Postgres user with pg_monitor role
#   2. Create the datadog.explain_statement function (required for explain plans!)
#
# Run this SQL as a superuser:
#
#   CREATE SCHEMA IF NOT EXISTS datadog;
#   GRANT USAGE ON SCHEMA datadog TO datadog;
#
#   CREATE OR REPLACE FUNCTION datadog.explain_statement(
#      l_query TEXT, OUT explain JSON
#   ) RETURNS SETOF JSON AS $$
#   DECLARE curs REFCURSOR; plan JSON;
#   BEGIN
#      OPEN curs FOR EXECUTE pg_catalog.concat('EXPLAIN (FORMAT JSON) ', l_query);
#      FETCH curs INTO plan; CLOSE curs;
#      RETURN QUERY SELECT plan;
#   END; $$ LANGUAGE 'plpgsql' RETURNS NULL ON NULL INPUT SECURITY DEFINER;
#
#   GRANT EXECUTE ON FUNCTION datadog.explain_statement(TEXT) TO datadog;
#
# See: https://docs.datadoghq.com/database_monitoring/setup_postgres/

init_config:

instances:
  - host: localhost
    port: 5432
    username: datadog
    password: <YOUR_DATADOG_MONITORING_USER_PASSWORD>
    dbname: ddstore

    # Enable Database Monitoring
    dbm: true

    collect_bloat_metrics: true

    query_samples:
      enabled: true

    query_metrics:
      enabled: true

    query_activity:
      enabled: true

    tags:
      - env:demo
      - service:ddstore-api
      - db:postgres
